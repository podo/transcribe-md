#!/usr/bin/env python3
"""
transcribe-to-md — Record and transcribe audio to a markdown file using whisper.cpp

Records from your microphone and system audio (via ScreenCaptureKit, no
BlackHole needed) and appends a timestamped transcript to the specified
markdown file.

Mic audio is labeled "You", system audio is labeled "Them", and both are
interleaved by timestamp into a single transcript.

First run installs ffmpeg (via Homebrew), builds whisper.cpp with Metal
acceleration, downloads the base.en model (~150 MB), and builds a small
Swift helper for system audio capture.

Usage:
    transcribe-to-md notes.md                    Record mic + system audio
    transcribe-to-md --mic-only notes.md          Record mic only
    transcribe-to-md --devices                    List mic devices
    transcribe-to-md --setup                      Install dependencies only
    transcribe-to-md --language lt meeting.md     Record in Lithuanian
    transcribe-to-md --language auto notes.md     Auto-detect language
"""

import argparse
import datetime
import difflib
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import tempfile
import threading
from pathlib import Path

# ── Configuration ──────────────────────────────────────────────────────────

# Resolve paths relative to this script so the skill is portable
SCRIPT_DIR = Path(__file__).resolve().parent

# Swift helper lives next to this script
SWIFT_PROJECT = SCRIPT_DIR / "system-audio-tap"
SYSTEM_TAP_BIN = SWIFT_PROJECT / ".build" / "release" / "system-audio-tap"

# Large build artifacts (whisper.cpp, models) stay in ~/.cache
CACHE_DIR = Path.home() / ".cache" / "transcribe-cli"
WHISPER_DIR = CACHE_DIR / "whisper.cpp"
MODEL_DIR = CACHE_DIR / "models"
DEFAULT_CHUNK = 10  # seconds

HF_BASE = "https://huggingface.co/ggerganov/whisper.cpp/resolve/main"

# Model registry: name -> (filename, download_url, multilingual)
MODELS = {
    "base.en": (
        "ggml-base.en.bin",
        f"{HF_BASE}/ggml-base.en.bin",
        False,  # English-only — never pass -l to whisper-cli
    ),
    "large-v3-turbo-q5": (
        "ggml-large-v3-turbo-q5_0.bin",
        f"{HF_BASE}/ggml-large-v3-turbo-q5_0.bin",
        True,   # multilingual
    ),
}
DEFAULT_MODEL = "base.en"

# ── Globals ────────────────────────────────────────────────────────────────

running = True
whisper_bin = None
active_model_path = None    # set by ensure_whisper() before recording
active_language_flag = None  # e.g. "lt", or None for English
pending_threads = []
file_lock = threading.Lock()

# Optional whisper initial prompt: biases the decoder toward a given vocabulary.
# Most useful for code-switched LT+English ("workshop", "skills", "API" etc.) so the
# model preserves English tech terms instead of phonetically rendering them back as
# Lithuanian-looking tokens.
INITIAL_PROMPT = None

# Optional post-transcription cleanup via Claude Code session (no API key required).
# When enabled, each transcribed segment passes through `claude -p` for typo/morphology
# correction before being written to the markdown output. Falls back silently to raw
# whisper output on any error so recording is never broken by cleanup failure.
ENHANCE = False
ENHANCE_MODEL = "sonnet"
CLAUDE_BIN = shutil.which("claude")

LT_CLEANUP_SYSTEM_PROMPT = (
    "You clean Lithuanian Whisper ASR transcripts. The input is a short utterance "
    "(typically 5-30 seconds of speech) with phonetic transcription errors and often "
    "English tech terms phonetically rendered into Lithuanian.\n\n"
    "Fix these issues:\n"
    "- Phonetic mangling (e.g. 'delikas' -> 'dalykas', 'vorkšapa' -> 'workshop')\n"
    "- Wrong morphology (case endings, declensions)\n"
    "- Missing word boundaries\n"
    "- Restore English tech terms to their proper English spelling\n\n"
    "Strict rules:\n"
    "- Output ONLY the cleaned transcript text — no preamble, no explanation, no quotes\n"
    "- Preserve speaker intent exactly — NEVER paraphrase or summarize\n"
    "- Don't add punctuation beyond what's clearly justified by source\n"
    "- Mark unrecoverable garbled sections as [unclear]\n"
    "- If input is empty or pure noise, return [unclear]"
)


def _llm_cleanup(text, prev_text=""):
    """Post-process a Whisper segment via `claude -p` (current Claude Code session auth).

    Uses --system-prompt to replace the default Claude Code system prompt (skips the
    ~46K-token skill-loading overhead per call, dropping per-chunk latency to ~3-5s).
    Returns raw text on any error so the recording loop is never broken by a cleanup
    failure (missing CLI, timeout, network error, malformed response).
    """
    if not CLAUDE_BIN or not text or not text.strip():
        return text
    user_msg = (f"Previous context: {prev_text}\n\n" if prev_text else "") + f"Clean: {text}"
    try:
        proc = subprocess.run(
            [CLAUDE_BIN, "-p", "--output-format", "json",
             "--system-prompt", LT_CLEANUP_SYSTEM_PROMPT,
             "--model", ENHANCE_MODEL, user_msg],
            capture_output=True, text=True, timeout=45, check=False,
        )
        if proc.returncode != 0:
            return text
        envelope = json.loads(proc.stdout)
        if envelope.get("is_error"):
            return text
        cleaned = (envelope.get("result") or "").strip()
        return cleaned or text
    except Exception:
        return text


def log(msg):
    ts = datetime.datetime.now().strftime("%H:%M:%S")
    print(f"\033[90m[{ts}]\033[0m {msg}", file=sys.stderr, flush=True)


# ── Dependency management ──────────────────────────────────────────────────


def ensure_ffmpeg():
    if shutil.which("ffmpeg"):
        return
    log("Installing ffmpeg via Homebrew...")
    subprocess.run(["brew", "install", "ffmpeg"], check=True)
    if not shutil.which("ffmpeg"):
        sys.exit("Error: ffmpeg installation failed")


def _find_whisper_bin():
    for name in ("whisper-cli", "main"):
        p = WHISPER_DIR / "build" / "bin" / name
        if p.exists() and os.access(p, os.X_OK):
            return p
    return None


def _ensure_whisper_binary():
    """Clone and build whisper.cpp if needed; sets whisper_bin global."""
    global whisper_bin
    CACHE_DIR.mkdir(parents=True, exist_ok=True)

    if not (WHISPER_DIR / "CMakeLists.txt").exists():
        log("Cloning whisper.cpp...")
        subprocess.run(
            [
                "git", "clone", "--depth", "1",
                "https://github.com/ggerganov/whisper.cpp.git",
                str(WHISPER_DIR),
            ],
            check=True,
        )

    whisper_bin = _find_whisper_bin()
    if not whisper_bin:
        log("Building whisper.cpp (Metal-accelerated)...")
        if not shutil.which("cmake"):
            log("Installing cmake via Homebrew...")
            subprocess.run(["brew", "install", "cmake"], check=True)
        build_dir = WHISPER_DIR / "build"
        subprocess.run(
            ["cmake", "-B", str(build_dir), "-DGGML_METAL=ON"],
            cwd=str(WHISPER_DIR),
            check=True,
        )
        subprocess.run(
            ["cmake", "--build", str(build_dir), "--config", "Release", "-j"],
            check=True,
        )
        whisper_bin = _find_whisper_bin()
        if not whisper_bin:
            sys.exit("Error: whisper.cpp build failed")
        log(f"Built: {whisper_bin}")


def ensure_whisper(model_name=DEFAULT_MODEL, language=None):
    global active_model_path, active_language_flag
    _ensure_whisper_binary()

    filename, url, multilingual = MODELS[model_name]
    model_path = MODEL_DIR / filename
    if not model_path.exists():
        MODEL_DIR.mkdir(parents=True, exist_ok=True)
        size_hint = "~500 MB" if "turbo" in filename else "~150 MB"
        log(f"Downloading {filename} ({size_hint})...")
        subprocess.run(
            ["curl", "-L", "--progress-bar", "-o", str(model_path), url],
            check=True,
        )
        log("Model ready")

    active_model_path = model_path
    active_language_flag = language if (multilingual and language and language != "en") else None


def ensure_system_audio_tap():
    """Build the Swift system-audio-tap helper if not already built."""
    if SYSTEM_TAP_BIN.exists() and os.access(SYSTEM_TAP_BIN, os.X_OK):
        return
    if not (SWIFT_PROJECT / "Package.swift").exists():
        log("system-audio-tap Swift project not found — skipping system audio")
        return
    log("Building system-audio-tap (Swift, ScreenCaptureKit)...")
    subprocess.run(
        ["swift", "build", "-c", "release"],
        cwd=str(SWIFT_PROJECT),
        check=True,
    )
    if not SYSTEM_TAP_BIN.exists():
        sys.exit("Error: system-audio-tap build failed")
    log(f"Built: {SYSTEM_TAP_BIN}")


def setup(model_name=DEFAULT_MODEL, language=None):
    if not shutil.which("brew"):
        sys.exit("Error: Homebrew is required — https://brew.sh")
    ensure_ffmpeg()
    ensure_whisper(model_name=model_name, language=language)
    ensure_system_audio_tap()


# ── Audio devices (mic only — system audio uses ScreenCaptureKit) ─────────


def list_audio_devices():
    """Return [(index, name), ...] from ffmpeg/AVFoundation."""
    r = subprocess.run(
        ["ffmpeg", "-f", "avfoundation", "-list_devices", "true", "-i", ""],
        capture_output=True,
        text=True,
    )
    in_audio = False
    devices = []
    for line in r.stderr.splitlines():
        if "AVFoundation audio devices:" in line:
            in_audio = True
            continue
        if in_audio:
            m = re.search(r"\[AVFoundation.*?\]\s+\[(\d+)\]\s+(.*)", line)
            if m:
                devices.append((int(m.group(1)), m.group(2).strip()))
    return devices


# ── Recording ──────────────────────────────────────────────────────────────


def record_mic_chunk(device_index, out_path, duration):
    """Record mic via ffmpeg. Returns Popen."""
    cmd = [
        "ffmpeg", "-y",
        "-f", "avfoundation",
        "-i", f":{device_index}",
        "-ac", "1",
        "-ar", "16000",
        "-t", str(duration),
        "-loglevel", "error",
        str(out_path),
    ]
    return subprocess.Popen(cmd, stdin=subprocess.DEVNULL)


def record_system_chunk(out_path, duration):
    """Record system audio via ScreenCaptureKit. Returns Popen."""
    cmd = [
        str(SYSTEM_TAP_BIN),
        "--output", str(out_path),
        "--duration", str(duration),
    ]
    return subprocess.Popen(cmd, stdin=subprocess.DEVNULL)


# ── Audio conversion ───────────────────────────────────────────────────────


def convert_to_whisper_format(in_path, out_path):
    """Convert any WAV to 16kHz mono PCM (what whisper expects)."""
    subprocess.run(
        [
            "ffmpeg", "-y",
            "-i", str(in_path),
            "-ac", "1",
            "-ar", "16000",
            "-loglevel", "error",
            str(out_path),
        ],
        check=True,
        timeout=30,
    )


# ── Transcription ──────────────────────────────────────────────────────────


def transcribe_timestamped(audio_path):
    """Run whisper and return [(start_sec, end_sec, text), ...]."""
    cmd = [str(whisper_bin), "-m", str(active_model_path), "-f", str(audio_path)]
    if active_language_flag:
        cmd += ["-l", active_language_flag]
    if INITIAL_PROMPT:
        cmd += ["--prompt", INITIAL_PROMPT]
    r = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=120,
    )
    segments = []
    combined = r.stdout + "\n" + r.stderr
    for line in combined.splitlines():
        m = re.match(
            r"\[(\d+):(\d+):(\d+\.\d+)\s*-->\s*(\d+):(\d+):(\d+\.\d+)\]\s*(.*)",
            line,
        )
        if m:
            s = int(m.group(1)) * 3600 + int(m.group(2)) * 60 + float(m.group(3))
            e = int(m.group(4)) * 3600 + int(m.group(5)) * 60 + float(m.group(6))
            text = m.group(7).strip()
            if text and not re.match(r"^\[.*\]$", text) and not re.match(
                r"^\(.*\)$", text
            ):
                segments.append((s, e, text))
    return segments


def transcribe_plain(audio_path):
    """Run whisper with no timestamps, return plain text."""
    cmd = [str(whisper_bin), "-m", str(active_model_path), "-f", str(audio_path), "-nt"]
    if active_language_flag:
        cmd += ["-l", active_language_flag]
    if INITIAL_PROMPT:
        cmd += ["--prompt", INITIAL_PROMPT]
    r = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=120,
    )
    text = r.stdout.strip()
    if not text:
        text = r.stderr.strip()
    text = re.sub(r"\[BLANK_AUDIO\]", "", text)
    text = re.sub(r"\(silence\)", "", text, flags=re.IGNORECASE)
    text = re.sub(r"(.{10,}?)\1{3,}", r"\1", text)
    return text.strip()


# ── Deduplication ──────────────────────────────────────────────────────────


def _text_similarity(a, b):
    """Return 0.0–1.0 similarity ratio between two strings."""
    return difflib.SequenceMatcher(None, a.lower(), b.lower()).ratio()


def _deduplicate(merged):
    """Remove mic segments that are echoes of system audio.

    When speakers are used (no headphones), the mic picks up whatever the
    computer is playing.  This produces near-duplicate segments where "You"
    and "Them" say almost the same thing at the same time.

    Strategy: for every "You" segment, look for a "Them" segment within
    ±5 seconds.  If the text similarity is >0.5, the mic just recorded the
    speaker output — drop the "You" segment and keep the cleaner "Them".
    """
    if not merged:
        return merged

    # Index Them segments for quick lookup
    them_segs = [(s, t) for s, speaker, t in merged if speaker == "Them"]

    drop = set()
    for i, (offset, speaker, text) in enumerate(merged):
        if speaker != "You":
            continue
        for them_offset, them_text in them_segs:
            if abs(offset - them_offset) > 5.0:
                continue
            if _text_similarity(text, them_text) > 0.5:
                drop.add(i)
                break

    if drop:
        log(f"Dedup: dropped {len(drop)} mic echo(es)")

    return [seg for i, seg in enumerate(merged) if i not in drop]


# ── Chunk processing ───────────────────────────────────────────────────────


def process_dual_chunk(mic_wav, sys_wav, md_path, chunk_start):
    """Transcribe mic + system audio, merge by timestamp, append to file."""
    sys_converted = None
    try:
        # Convert system audio from 48kHz stereo to 16kHz mono for whisper
        sys_converted = sys_wav.with_suffix(".16k.wav")
        convert_to_whisper_format(sys_wav, sys_converted)

        mic_segs = transcribe_timestamped(mic_wav)
        sys_segs = transcribe_timestamped(sys_converted)

        merged = []
        for s, _e, t in mic_segs:
            merged.append((s, "You", t))
        for s, _e, t in sys_segs:
            merged.append((s, "Them", t))
        merged.sort(key=lambda x: x[0])

        # Remove mic segments that are echoes of system audio
        merged = _deduplicate(merged)

        if not merged:
            log("(no speech detected)")
            return

        # Optional LLM cleanup pass — runs in this chunk's worker thread so it
        # parallelizes naturally with the *next* chunk's whisper invocation.
        if ENHANCE:
            cleaned = []
            prev = ""
            for offset, speaker, text in merged:
                clean = _llm_cleanup(text, prev)
                cleaned.append((offset, speaker, clean))
                prev = clean
            merged = cleaned

        lines = []
        for offset, speaker, text in merged:
            abs_time = chunk_start + datetime.timedelta(seconds=offset)
            ts = abs_time.strftime("%H:%M:%S")
            lines.append(f"**[{ts}] {speaker}:** {text}")

        block = "\n\n".join(lines) + "\n\n"
        with file_lock:
            with open(md_path, "a") as f:
                f.write(block)

        preview = merged[0][2][:80] if merged else ""
        log(f"{len(merged)} segment(s) transcribed -- {preview}")

    except Exception as exc:
        log(f"Transcription error: {exc}")
    finally:
        for p in (mic_wav, sys_wav, sys_converted):
            if p is None:
                continue
            try:
                os.unlink(p)
            except OSError:
                pass


def process_single_chunk(mic_wav, md_path, chunk_start):
    """Transcribe mic audio, append to file."""
    try:
        text = transcribe_plain(mic_wav)
        if not text:
            log("(no speech detected)")
            return

        if ENHANCE:
            text = _llm_cleanup(text)

        ts = chunk_start.strftime("%H:%M:%S")
        with file_lock:
            with open(md_path, "a") as f:
                f.write(f"**[{ts}]** {text}\n\n")

        log(f"{text[:80]}{'...' if len(text) > 80 else ''}")

    except Exception as exc:
        log(f"Transcription error: {exc}")
    finally:
        try:
            os.unlink(mic_wav)
        except OSError:
            pass


# ── Main loop ──────────────────────────────────────────────────────────────


def run(md_path, mic_idx, dual, chunk_duration, duration_minutes=None):
    global running

    tmp = Path(tempfile.mkdtemp(prefix="transcribe_"))
    n = 0

    deadline = None
    if duration_minutes:
        deadline = datetime.datetime.now() + datetime.timedelta(minutes=duration_minutes)

    now = datetime.datetime.now()
    lang_note = f" [{active_language_flag.upper()}]" if active_language_flag else ""
    with open(md_path, "a") as f:
        f.write(f"\n\n---\n\n## Transcript{lang_note} -- {now.strftime('%Y-%m-%d %H:%M')}\n\n")

    mode = "Dual (mic + system)" if dual else "Mic only"
    log(f"Output: {md_path}")
    dur_str = f" | Duration: {duration_minutes}min" if duration_minutes else ""
    log(f"Mode: {mode} | Chunk: {chunk_duration}s{dur_str}")
    if deadline:
        log(f"Will auto-stop at {deadline.strftime('%H:%M:%S')}")
    log("Press Ctrl-C to stop\n")

    def on_signal(sig, _frame):
        global running
        running = False

    signal.signal(signal.SIGINT, on_signal)
    signal.signal(signal.SIGTERM, on_signal)

    try:
        while running:
            # Check if timed recording has expired
            if deadline and datetime.datetime.now() >= deadline:
                log(f"Duration reached ({duration_minutes}min) — stopping.")
                break

            n += 1
            chunk_start = datetime.datetime.now()

            # Start mic recording
            mic_wav = tmp / f"mic_{n:05d}.wav"
            mic_proc = record_mic_chunk(mic_idx, mic_wav, chunk_duration)

            # Start system audio recording (via ScreenCaptureKit)
            sys_proc = None
            sys_wav = None
            if dual:
                sys_wav = tmp / f"sys_{n:05d}.wav"
                sys_proc = record_system_chunk(sys_wav, chunk_duration)

            # Wait for recordings to complete
            mic_proc.wait()
            if sys_proc:
                sys_proc.wait()

            # Check we got usable audio
            if not mic_wav.exists() or mic_wav.stat().st_size < 1000:
                if not running:
                    break
                continue

            # Transcribe in background thread
            if dual and sys_wav and sys_wav.exists() and sys_wav.stat().st_size > 1000:
                t = threading.Thread(
                    target=process_dual_chunk,
                    args=(mic_wav, sys_wav, md_path, chunk_start),
                    daemon=True,
                )
            else:
                # Fall back to mic-only if system audio is empty
                if sys_wav and sys_wav.exists():
                    try:
                        os.unlink(sys_wav)
                    except OSError:
                        pass
                t = threading.Thread(
                    target=process_single_chunk,
                    args=(mic_wav, md_path, chunk_start),
                    daemon=True,
                )
            t.start()
            pending_threads.append(t)

            pending_threads[:] = [t for t in pending_threads if t.is_alive()]

    finally:
        if pending_threads:
            log("Finishing pending transcriptions...")
            for t in pending_threads:
                t.join(timeout=60)
        shutil.rmtree(tmp, ignore_errors=True)
        log("Done.")


# ── CLI ────────────────────────────────────────────────────────────────────


def main():
    p = argparse.ArgumentParser(
        description="Record & transcribe audio to markdown (whisper.cpp + ScreenCaptureKit)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s notes.md                      Record mic + system audio -> notes.md
  %(prog)s --duration 30 meeting.md      Record for 30 minutes then auto-stop
  %(prog)s --mic-only notes.md           Record mic only (no system audio)
  %(prog)s --devices                     List mic devices
  %(prog)s --mic 2 notes.md              Use specific mic
  %(prog)s --chunk 30 notes.md           Use 30-second chunks
  %(prog)s --setup                       Install dependencies only
  %(prog)s --language lt susitikimas.md  Record in Lithuanian
  %(prog)s --language auto notes.md      Auto-detect spoken language
        """,
    )
    p.add_argument("file", nargs="?", help="Markdown file to append transcript to")
    p.add_argument(
        "--setup", action="store_true", help="Install dependencies and exit"
    )
    p.add_argument(
        "--devices", action="store_true", help="List audio input devices"
    )
    p.add_argument(
        "--duration", type=float, default=None, metavar="MIN",
        help="Auto-stop after this many minutes (e.g., 30 for a 30-min meeting)",
    )
    p.add_argument(
        "--mic", type=int, default=None, metavar="IDX",
        help="Microphone device index (default: auto-detect)",
    )
    p.add_argument(
        "--mic-only", action="store_true",
        help="Record microphone only (skip system audio capture)",
    )
    p.add_argument(
        "--chunk", type=int, default=None, metavar="SEC",
        help=(
            f"Chunk duration in seconds. Default: {DEFAULT_CHUNK}s for English, "
            "20s for non-English languages (Whisper was trained on 30s windows, so "
            "10s chunks fragment mid-word on inflectional languages like Lithuanian)."
        ),
    )
    default_lang = os.environ.get("TRANSCRIBE_MD_LANGUAGE", "en")
    p.add_argument(
        "--language", "-l", default=default_lang, metavar="LANG",
        help=(
            f"Spoken language code (default: {default_lang!r}, from "
            "$TRANSCRIBE_MD_LANGUAGE env var). Use 'lt' for Lithuanian, "
            "'auto' to auto-detect. Non-English languages automatically use "
            "the multilingual model (~500 MB, downloaded once)."
        ),
    )
    p.add_argument(
        "--model", default=None, metavar="NAME_OR_PATH",
        help=(
            "Override model. Built-in names: base.en, large-v3-turbo-q5. "
            "Or provide an absolute path to a custom .bin file."
        ),
    )
    p.add_argument(
        "--prompt", default=None, metavar="TEXT",
        help=(
            "Initial-prompt vocabulary hint passed to whisper. Most useful for "
            "code-switched LT+English speech (e.g. --prompt 'workshop design API "
            "frontend backend prototype') — biases the decoder to preserve English "
            "tech terms instead of phonetically rendering them as Lithuanian."
        ),
    )
    p.add_argument(
        "--enhance", action="store_true",
        help=(
            "Post-process each transcribed segment through `claude -p` (your current "
            "Claude Code session — no separate API key needed) to correct phonetic "
            "errors, fix morphology, and restore code-switched English tech terms. "
            "Adds ~3-5s per chunk but runs in parallel with the next chunk's whisper, "
            "so real-time feel is preserved. Falls back to raw whisper output on any "
            "cleanup failure."
        ),
    )
    p.add_argument(
        "--enhance-model", default="sonnet", metavar="ALIAS",
        help=(
            "Model alias for --enhance cleanup (default: sonnet). Passed to "
            "`claude --model`. Examples: sonnet, opus, haiku."
        ),
    )

    args = p.parse_args()

    # ── Resolve enhancement + prompt options ──────────────────────────
    global ENHANCE, ENHANCE_MODEL, INITIAL_PROMPT
    ENHANCE = bool(args.enhance)
    ENHANCE_MODEL = args.enhance_model or "sonnet"
    INITIAL_PROMPT = args.prompt
    if ENHANCE and not CLAUDE_BIN:
        log("Warning: --enhance requested but `claude` CLI not on PATH; cleanup will be skipped per chunk.")

    # ── Resolve language and model ─────────────────────────────────────
    language = (args.language or "en").lower()

    # Non-English defaults: bump chunk size from 10s -> 20s. Whisper was trained on
    # 30s windows, so 10s chunks cause mid-word splices on inflectional languages.
    if args.chunk is None:
        chunk_duration = DEFAULT_CHUNK if language == "en" else 20
    else:
        chunk_duration = args.chunk
    args.chunk = chunk_duration

    if args.model and Path(args.model).exists():
        # User provided a path to a local .bin (e.g., GGML fine-tuned model)
        global active_model_path, active_language_flag
        active_model_path = Path(args.model)
        active_language_flag = language if language != "en" else None
        if not shutil.which("brew"):
            sys.exit("Error: Homebrew is required — https://brew.sh")
        ensure_ffmpeg()
        _ensure_whisper_binary()
        ensure_system_audio_tap()
    else:
        if args.model and args.model not in MODELS:
            p.error(f"Unknown model '{args.model}'. Valid names: {', '.join(MODELS)}")
        if args.model:
            chosen_model = args.model
        elif language == "en":
            chosen_model = "base.en"
        else:
            chosen_model = "large-v3-turbo-q5"
            log(f"Language '{language}' — using multilingual model (large-v3-turbo-q5, ~500 MB, one-time download)")
        setup(model_name=chosen_model, language=language)

    if args.setup:
        log("All dependencies ready.")
        log(f"Model: {active_model_path}")
        return

    # ── List devices ───────────────────────────────────────────────────
    if args.devices:
        devs = list_audio_devices()
        if not devs:
            print("No audio devices found.")
        else:
            print("Microphone devices (use index with --mic):\n")
            for idx, name in devs:
                print(f"  [{idx}]  {name}")
            print("\n  System audio is captured automatically via ScreenCaptureKit.")
            print("  No extra devices or setup needed.")
        return

    # ── Validate ───────────────────────────────────────────────────────
    if not args.file:
        p.error("Please provide a markdown file path")

    md_path = Path(args.file).resolve()
    md_path.parent.mkdir(parents=True, exist_ok=True)
    if not md_path.exists():
        md_path.touch()

    # ── Select mic ─────────────────────────────────────────────────────
    devs = list_audio_devices()
    if not devs:
        sys.exit("Error: no audio devices found")

    mic_idx = args.mic
    if mic_idx is None:
        for idx, name in devs:
            if "macbook" in name.lower() and "mic" in name.lower():
                mic_idx = idx
                break
        if mic_idx is None:
            mic_idx = devs[0][0]

    mic_name = next((n for i, n in devs if i == mic_idx), f"Device {mic_idx}")
    log(f"Mic: [{mic_idx}] {mic_name}")

    # ── Determine dual mode ────────────────────────────────────────────
    dual = False
    if not args.mic_only:
        if SYSTEM_TAP_BIN.exists() and os.access(SYSTEM_TAP_BIN, os.X_OK):
            dual = True
            log("System audio: ScreenCaptureKit (automatic)")
        else:
            log("System audio: not available (system-audio-tap not built)")
    else:
        log("System audio: disabled (--mic-only)")

    # ── Run ────────────────────────────────────────────────────────────
    run(md_path, mic_idx, dual, args.chunk, args.duration)


if __name__ == "__main__":
    main()
